<Window x:Class="PersistenceAuditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Persistence Auditor V1.0" Height="700" Width="1200"
        WindowStyle="None" 
        AllowsTransparency="True" 
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas">

    <Window.Background>
        <ImageBrush ImageSource="/Images/GUIBackground21.jfif" Stretch="UniformToFill" Opacity="1.0" RenderOptions.BitmapScalingMode="HighQuality"/>
    </Window.Background>

    <Window.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#15151A"/>
            <Setter Property="Foreground" Value="#D1C4E9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2844"/>
                                <Setter Property="Foreground" Value="{StaticResource ColorFuture}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#11101A"/>
                                <Setter Property="Foreground" Value="{StaticResource ColorNetwork}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#15151A" MouseLeftButtonDown="TitleBar_MouseDown">
            <TextBlock Text="PERSISTENCE AUDITOR V3.0 - THREAT HUNTING CONSOLE" Foreground="#A09DB0" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="11" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🗕" Click="BtnMinimize_Click" Width="40" Background="Transparent" Foreground="#A09DB0" BorderThickness="0" Cursor="Hand" FontSize="14"/>
                <Button Content="🗖" Click="BtnMaximize_Click" Width="40" Background="Transparent" Foreground="#A09DB0" BorderThickness="0" Cursor="Hand" FontSize="14"/>
                <Button Content="✕" Click="BtnClose_Click" Width="40" Background="Transparent" Foreground="#A09DB0" BorderThickness="0" Cursor="Hand" FontSize="14"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="#15151A" BorderBrush="#2D2844" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnStartHunt" Grid.Column="0" Content="INITIATE DEEP SCAN" Style="{StaticResource CyberButton}" Width="220" Height="40" Click="BtnStartHunt_Click"/>

                <Button x:Name="BtnExportHunt" Grid.Column="1" Content="EXPORT TO CLIPBOARD" Style="{StaticResource CyberButton}" Background="{StaticResource ColorFuture}" Width="200" Height="40" Margin="15,0,0,0" Click="BtnExportHunt_Click" IsEnabled="False"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock x:Name="TxtLocalAudit" Text="LOCAL AUDIT" Foreground="#00FFFF" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00FFFF" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <CheckBox x:Name="ChkRoutingMode" Style="{StaticResource CyberToggle}" Checked="ChkRoutingMode_Checked" Unchecked="ChkRoutingMode_Unchecked"/>

                        <TextBlock x:Name="TxtApiDispatch" Text="API DISPATCH" Foreground="#55516B" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    </StackPanel>                    
                    <TextBlock Text="FILTER:" Foreground="#A09DB0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Background="#11101A" BorderBrush="#FF6D00" BorderThickness="2" CornerRadius="4" Width="150" Height="30" Margin="0,0,20,0" Opacity="1.0">
                        <ComboBox x:Name="CmbSeverityFilter" SelectionChanged="CmbSeverityFilter_SelectionChanged" Background="#A09DB0" Foreground="#FF181222" BorderThickness="0" Opacity="0.3" FontSize="14" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="All Severities" IsSelected="True"/>
                            <ComboBoxItem Content="Critical (Red)"/>
                            <ComboBoxItem Content="Suspicious (Yellow)"/>
                        </ComboBox>
                    </Border>
                    <Border Background="#11101A" BorderBrush="{StaticResource ColorIdentity}" BorderThickness="2" CornerRadius="4" Width="250" Height="30">
                        <Grid>
                            <TextBlock x:Name="TxtSearchPlaceholder" Text="Search registry paths, names..." Foreground="#55516B" VerticalAlignment="Center" Margin="10,0" IsHitTestVisible="False"/>
                            <TextBox x:Name="TxtSearch" Background="Transparent" Foreground="White" CaretBrush="White" BorderThickness="0" VerticalAlignment="Center" Margin="10,0" TextChanged="TxtSearch_TextChanged"/>
                        </Grid>    
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="GridThreats" Grid.Row="2" Margin="20" Background="Transparent" BorderThickness="0"
                  RowBackground="#15151A" AlternatingRowBackground="#1A1A24" 
                  Foreground="#D1C4E9" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2D2844"
                  AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single"
                  HeadersVisibility="Column" SelectionChanged="GridThreats_SelectionChanged">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#11101A"/>
                    <Setter Property="Foreground" Value="{StaticResource ColorFuture}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,10,10,10"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="{StaticResource ColorFuture}"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#2D2844"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
                <Style TargetType="DataGridCell" x:Key="SeverityColorStyle">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Severity}" Value="CRITICAL">
                            <Setter Property="Foreground" Value="#FF1744"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Severity}" Value="SUSPICIOUS">
                            <Setter Property="Foreground" Value="#FFEA00"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Severity}" Value="BASELINE">
                            <Setter Property="Foreground" Value="#39FF14"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="SEVERITY" Binding="{Binding Severity}" Width="100" IsReadOnly="True" CellStyle="{StaticResource SeverityColorStyle}"/>
                <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="ENTRY NAME" Binding="{Binding Name}" Width="250" IsReadOnly="True"/>
                <DataGridTextColumn Header="TARGET PATH / COMMAND" Binding="{Binding Path}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="120" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="#11101A" BorderBrush="{StaticResource ColorFuture}" BorderThickness="0,2,0,0">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="SELECTED ARTIFACT DETAILS" Foreground="{StaticResource ColorFuture}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TxtDetailName" Text="No item selected." Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtDetailPath" Text="---" Foreground="#A09DB0" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnDispatch" Content="DISPATCH THREAT" Style="{StaticResource CyberButton}" Background="{StaticResource ColorIdentity}" IsEnabled="False" Click="BtnDispatch_Click" Margin="0,0,15,0"/>
                    <Button x:Name="BtnRemediate" Content="DELETE ARTIFACT" Style="{StaticResource CyberButton}" Background="#FF6D00" IsEnabled="False" Click="BtnRemediate_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
