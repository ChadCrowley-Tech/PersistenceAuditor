<Window x:Class="PersistenceAuditor.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading Persistence Auditor" Height="450" Width="750"
        WindowStyle="None" AllowsTransparency="True" 
        WindowStartupLocation="CenterScreen" FontFamily="Consolas">

    <Window.Background>
        <ImageBrush ImageSource="/Images/GUIBackground21.jfif" Stretch="UniformToFill" Opacity="1.0" RenderOptions.BitmapScalingMode="HighQuality"/>
    </Window.Background>

    <Border CornerRadius="15" BorderBrush="#2D2844" BorderThickness="2" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="10" Opacity="0.8"/>
        </Border.Effect>

        <Border BorderBrush="{StaticResource ColorNetwork}" BorderThickness="1" CornerRadius="10" Margin="25">
            <Border.Effect>
                <DropShadowEffect Color="#00E5FF" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="[PERSISTENCE_AUDITOR]" Foreground="{StaticResource ColorNetwork}" FontSize="52" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00E5FF" BlurRadius="25" ShadowDepth="0" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Text="V3.0 - Persistence auditing dashboard and remediation options" Foreground="{StaticResource TextSecondary}" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,60"/>

                <Button x:Name="BtnGetStarted" Content="SYSTEM LINK : INITIATE" Width="300" Height="55" Style="{StaticResource CyberButton}" Click="BtnGetStarted_Click" FontSize="18"/>

            </StackPanel>
        </Border>
    </Border>
</Window>
